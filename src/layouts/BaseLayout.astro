---
import { ClientRouter } from "astro:transitions";
import { profile } from "@/data/profile";
import "@/styles/global.css";

type Props = {
  title?: string;
  description?: string;
  canonical?: string;
  hideChrome?: boolean;
};

const {
  title = profile.name,
  description = profile.role,
  canonical = Astro.url.pathname,
  hideChrome = false
} = Astro.props;

const currentPath = Astro.url.pathname;
const isHome = currentPath === "/";
const pageTitle =
  isHome
    ? profile.homeSeo.title
    : title === profile.name
      ? title
      : `${title} | ${profile.name}`;
const metaDescription = isHome ? profile.homeSeo.description : description;
const socialTitle = isHome ? profile.homeSeo.socialTitle : pageTitle;
const socialDescription = profile.homeSeo.socialDescription;
const canonicalUrl = new URL(canonical, Astro.site ?? "https://alexfili.pe").toString();
const assetVersion = "20260624-dodecahedron";
const assetSuffix = `?v=${assetVersion}`;
const ogImageUrl = new URL(`/og-image.png${assetSuffix}`, Astro.site ?? "https://alexfili.pe").toString();
const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: profile.name,
  alternateName: [profile.shortName, profile.domain],
  url: "https://alexfili.pe/"
};
const navItems = [
  { href: "/", label: "Home" }
];

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#050504" />
    <meta name="application-name" content={profile.name} />
    <meta name="apple-mobile-web-app-title" content={profile.shortName} />
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={`/favicon.ico${assetSuffix}`} sizes="any" />
    <link rel="shortcut icon" href={`/favicon.ico${assetSuffix}`} />
    <link rel="icon" href={`/favicon.svg${assetSuffix}`} type="image/svg+xml" />
    <link rel="icon" href={`/favicon-16x16.png${assetSuffix}`} sizes="16x16" type="image/png" />
    <link rel="icon" href={`/favicon-32x32.png${assetSuffix}`} sizes="32x32" type="image/png" />
    <link rel="icon" href={`/icons/favicon-48.png${assetSuffix}`} sizes="48x48" type="image/png" />
    <link rel="apple-touch-icon" href={`/apple-touch-icon.png${assetSuffix}`} sizes="180x180" />
    <link rel="manifest" href={`/site.webmanifest${assetSuffix}`} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={profile.name} />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={socialDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${profile.name} - ${profile.tagline}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={socialDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
    <title>{pageTitle}</title>
    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class:list={["site-shell", hideChrome && "site-shell--bare"]}>
      {
        !hideChrome && (
          <header class="site-header">
            <nav class="site-nav" aria-label="Primary navigation">
              <a class="site-mark" href="/" aria-label={`${profile.name} home`}>
                {profile.shortName}
              </a>
              <div class="nav-links">
                {navItems.map((item) => (
                  <a
                    href={item.href}
                    aria-current={currentPath === item.href || currentPath === item.href.replace(/\/$/, "") ? "page" : undefined}
                  >
                    {item.label}
                  </a>
                ))}
              </div>
            </nav>
          </header>
        )
      }
      <main id="main">
        <slot />
      </main>
      {
        !hideChrome && (
          <footer class="site-footer">
            <div class="footer-inner">
              <span>© {new Date().getFullYear()} {profile.name}. Built with Astro.</span>
              <div class="footer-links">
                <a href={profile.github}>GitHub</a>
                <a href={profile.linkedin}>LinkedIn</a>
                <a href={`mailto:${profile.email}`}>Email</a>
              </div>
            </div>
          </footer>
        )
      }
    </div>
  </body>
</html>
