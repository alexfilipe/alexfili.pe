---
type Props = {
  label?: string;
};

const { label = "Piano line motif" } = Astro.props;
---

<div class="piano-staff" aria-label={label}>
  {
    Array.from({ length: 18 }, (_, index) => (
      <span class={`key key-${index % 7}`} />
    ))
  }
</div>

<style>
  .piano-staff {
    position: relative;
    display: grid;
    grid-template-columns: repeat(18, minmax(1.2rem, 1fr));
    gap: 0.18rem;
    min-height: 8rem;
    overflow: clip;
    border-block: 1px solid rgba(245, 240, 232, 0.12);
    background:
      repeating-linear-gradient(to bottom, transparent 0 1.35rem, rgba(245, 240, 232, 0.12) 1.35rem calc(1.35rem + 1px)),
      linear-gradient(90deg, transparent, rgba(211, 178, 112, 0.05), transparent);
    transform: perspective(780px) rotateX(62deg);
    transform-origin: bottom center;
  }

  .key {
    display: block;
    height: 4.7rem;
    border: 1px solid rgba(245, 240, 232, 0.2);
    background: rgba(245, 240, 232, 0.08);
  }

  .key:nth-child(3n + 1),
  .key:nth-child(4n + 2) {
    height: 3.1rem;
    background: rgba(245, 240, 232, 0.18);
    transform: translateY(-1.15rem);
  }
</style>
