---
const target = "/projects/";
const canonicalUrl = new URL(target, Astro.site ?? "https://alexfili.pe").toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <meta name="robots" content="noindex, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <title>Redirecting to Featured Work | Álex Filipe Santos</title>
  </head>
  <body>
    <p><a href={target}>Go to projects</a></p>
  </body>
</html>
