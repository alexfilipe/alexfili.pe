---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";

const writings = (await getCollection("writings"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const featured = writings.find((entry) => entry.data.featured) ?? writings[0];
---

<BaseLayout
  title="Writings"
  description="Essays and notes on AI, software, design, mathematics, and music by Álex Filipe Santos."
>
  <div class="page-motif">
    <section class="page-hero" aria-labelledby="writings-page-title">
      <h1 class="page-title" id="writings-page-title">Writings</h1>
      <p class="page-intro">
        Essays on technology, design, mathematical thought, and classical musicianship.
      </p>
    </section>
  </div>

  {
    featured && (
      <section class="section compact" aria-labelledby="featured-title">
        <div class="feature-panel" data-reveal>
          <div class="item-kicker">Featured Essay</div>
          <h2 id="featured-title">{featured.data.title}</h2>
          <p>{featured.data.description}</p>
          <div class="button-row">
            <a class="text-button" href={`/writings/${featured.id}/`}>Read</a>
          </div>
        </div>
      </section>
    )
  }

  <section class="section" aria-labelledby="essays-title">
    <div class="section-header">
      <h2 class="section-title" id="essays-title">Essays</h2>
      <p class="section-intro">
        A small but growing index, backed by typed MDX content so writing can stay as simple as editing a file.
      </p>
    </div>
    <div class="writing-list" data-reveal>
      {
        writings.map((entry) => (
          <article class="writing-item">
            <div class="item-kicker">{entry.data.tags[0] ?? "Essay"}</div>
            <div>
              <h2 class="item-title">
                <a href={`/writings/${entry.id}/`}>{entry.data.title}</a>
              </h2>
              <p class="item-description">{entry.data.description}</p>
              <div class="tags">
                {entry.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
            <div class="item-meta">
              {entry.data.publishedAt.toLocaleDateString("en-US", {
                month: "short",
                day: "numeric",
                year: "numeric",
                timeZone: "UTC"
              })}
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
