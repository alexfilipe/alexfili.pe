---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found" description="The requested page could not be found.">
  <section class="page-hero" aria-labelledby="not-found-title">
    <h1 class="page-title" id="not-found-title">Not Found</h1>
    <p class="page-intro">
      This page is not part of the score. Return home, or keep exploring the site from the navigation.
    </p>
    <div class="button-row">
      <a class="text-button" href="/">Home</a>
      <a class="text-button" href="/writings/">Writings</a>
    </div>
  </section>
</BaseLayout>
