---
import BaseLayout from "@/layouts/BaseLayout.astro";
import WorkIndex from "@/components/WorkIndex.tsx";
import { getProjectsItemList, seoPages } from "@/data/seo";
import "@/styles/global.css";
import "@/styles/pages.css";

const structuredData = getProjectsItemList(Astro.site);
---

<BaseLayout {...seoPages.projects} canonical={seoPages.projects.path} structuredData={structuredData}>
  <WorkIndex client:visible />
</BaseLayout>
